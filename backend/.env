PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://project-admin:g3G2DxP0oVArlJNj@aktu-cluster.nhziurk.mongodb.net/?appName=aktu-cluster

# JWT secret — use a long random string (e.g. generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email config — Gmail recommended (use App Password, NOT your real password)
# Enable App Passwords: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=5871
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# Admin email — where report notifications are sent
ADMIN_EMAIL=your_email@gmail.com
